{
  "name": "@aram10/dramaturge",
  "version": "0.2.0",
  "description": "Exploratory QA engine for web applications with UI, API, and evidence-backed replay",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aram10/dramaturge.git"
  },
  "homepage": "https://github.com/aram10/dramaturge#readme",
  "bugs": {
    "url": "https://github.com/aram10/dramaturge/issues"
  },
  "license": "GPL-3.0-only",
  "author": "Alex Rambasek (https://github.com/aram10)",
  "keywords": [
    "qa",
    "testing",
    "exploratory-testing",
    "playwright",
    "browser-testing",
    "test-automation",
    "web-testing",
    "agentic",
    "llm"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "dramaturge": "./dist/cli.js",
    "dramaturge-auth-state": "./dist/bin/export-auth-state.js"
  },
  "files": [
    "dist",
    "README.md",
    "dramaturge.config.example.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.3",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm run clean && tsc",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "pack:check": "npm pack --dry-run",
    "prepack": "pnpm run build && pnpm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:standalone": "node scripts/verify-standalone.mjs",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@browserbasehq/stagehand": "^3.2.0",
    "ajv": "^8.18.0",
    "ink": "^5.1.0",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "react": "^18.3.1",
    "yaml": "^2.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.1"
  }
}
