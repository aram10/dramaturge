{
  "targetUrl": "https://todomvc.com/examples/react/dist/",
  "appDescription": "TodoMVC React implementation - a simple todo list application with add, edit, complete, and delete functionality. Users can mark todos as complete, filter by status (all/active/completed), and clear completed items.",

  "models": {
    "planner": "anthropic/claude-sonnet-4-6",
    "worker": "anthropic/claude-haiku-4-5",
    "agentMode": "dom",
    "agentModes": {
      "navigation": "dom",
      "form": "dom",
      "crud": "dom"
    }
  },

  "budget": {
    "maxTasks": 20,
    "timeLimitSeconds": 300
  },

  "policy": {
    "maxNavigationDepth": 3,
    "allowOffSite": false
  },

  "output": {
    "dir": "./benchmarks/results/todomvc-react",
    "format": ["markdown", "json"]
  }
}
