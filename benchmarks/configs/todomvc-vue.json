{
  "targetUrl": "https://todomvc.com/examples/vue/",
  "appDescription": "TodoMVC Vue implementation - a simple todo list application. Features include adding new todos, marking todos as complete, editing existing todos, deleting todos, and filtering by completion status.",

  "models": {
    "planner": "anthropic/claude-sonnet-4-6",
    "worker": "anthropic/claude-haiku-4-5",
    "agentMode": "dom",
    "agentModes": {
      "navigation": "dom",
      "form": "dom",
      "crud": "dom"
    }
  },

  "budget": {
    "maxTasks": 20,
    "timeLimitSeconds": 300
  },

  "policy": {
    "maxNavigationDepth": 3,
    "allowOffSite": false
  },

  "output": {
    "dir": "./benchmarks/results/todomvc-vue",
    "format": ["markdown", "json"]
  }
}
